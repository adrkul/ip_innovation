@misc{Alfaro.Chor2023,
  type = {Working {{Paper}}},
  title = {Global {{Supply Chains}}: {{The Looming}} ``{{Great Reallocation}}''},
  shorttitle = {Global {{Supply Chains}}},
  author = {Alfaro, Laura and Chor, Davin},
