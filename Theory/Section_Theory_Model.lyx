\begin_inset Formula 
\[
\max_{p_{j},I_{j,A},I_{j,I}}D\left(p_{j}\right)^{-\sigma}\times\left(p_{j}-\frac{c_{j,A}}{I_{j,A}^{\rho}}-\frac{c_{j,I}}{I_{j,I}^{\rho}}\right)-r\left(I_{j,A}+I_{j,I}\right)
\]

\end_inset


\begin_inset Formula 
\[
\frac{I_{j,I}}{I_{j,A}+I_{j,I}}=\frac{\left(c_{j,I}\right)^{\frac{1}{\rho+1}}}{\left(c_{j,I}\right)^{\frac{1}{\rho+1}}+\left(c_{j,A}\right)^{\frac{1}{\rho+1}}}.
\]

\end_inset


