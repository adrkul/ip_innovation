\begin_layout Plain Layout
\begin_inset Formula 
\[
I_{j,A}+I_{j,I}=\lambda_{1}D^{\frac{1}{1+\rho\left(1-\sigma\right)}}\left(\left(c_{j,I}\right)^{\frac{1}{\rho+1}}+\left(c_{j,A}\right)^{\frac{1}{\rho+1}}\right)^{\frac{\left(\rho+1\right)\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}}
\]

\end_inset


\begin_inset Formula 
\[
p_{j}=\frac{\sigma}{\sigma-1}\left(\frac{c_{A}}{I_{j,A}^{\rho}}+\frac{c_{I}}{I_{j,I}^{\rho}}\right)
\]

\end_inset

So we have
\begin_inset Formula 
\[
\pi\left(I_{j,A},I_{j,I},K_{,jA},K_{,jI}\right)=\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{,jI}}\right)\right)^{1-\sigma}D-r\left(I_{j,A}+I_{j,I}\right)
\]

\end_inset

Then we have 
\begin_inset Formula 
\[
V\left(K_{,jA},K_{,jI}\right)=\max_{I_{j,A},I_{j,I}}\pi\left(I_{j,A},I_{j,I},K_{,jA},K_{,jI}\right)+\beta V\left(K_{j,A}\left(1-\delta\right)+I_{j,A},K_{,jI}\left(1-\delta\right)+I_{j,A}\right)
\]

\end_inset

So in steady state we require
\begin_inset Formula 
\[
K_{t+1}=K_{t}\left(1-\delta\right)+I_{t}
\]

\end_inset

So we require
\begin_inset Formula 
\[
K=\frac{1}{\delta}I.
\]

\end_inset

Then we have
\begin_inset Formula 
\[
\left(1-\beta\right)V\left(K_{,jA},K_{,jI}\right)=\max_{I_{j,A},I_{j,I}}\pi\left(I_{j,A},I_{j,I},\frac{1}{\delta}I_{j,A},\frac{1}{\delta}I_{j,I}\right)
\]

\end_inset

From which we have 
\begin_inset Formula 
\[
\max_{I_{j,A},I_{j,I}}\pi\left(I_{j,A},I_{j,I},\frac{1}{\delta}I_{j,A},\frac{1}{\delta}I_{j,I}\right)
\]

\end_inset

So we have FOC 
\begin_inset Formula 
\[
