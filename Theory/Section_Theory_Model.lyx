\begin_layout Plain Layout
\begin_inset Formula $\max_{x_{0},x_{j}}x_{0}+\left(\sum_{j\in N}x_{j}^{\frac{\sigma-1}{\sigma}}\right)^{\frac{\sigma}{\sigma-1}\beta}$
\end_inset


\end_layout

\end_inset


