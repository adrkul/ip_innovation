\]

\end_inset


\begin_inset Formula 
\[
\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{A}}{K_{,jA}}I_{j,A}^{-\rho-1}\rho-r+\beta V_{A}=0
\]

\end_inset

And we have envelope conditions 
\begin_inset Formula 
\[
V_{I}=\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{I}}{I_{j,I}^{\rho}}K_{j,I}^{-2}-r+\delta V_{I}
\]

\end_inset


\begin_inset Formula 
\[
V_{A}=\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{A}}{I_{j,A}^{\rho}}K_{,jA}^{-2}-r+\delta V_{A}
\]

\end_inset

Now impose steady state conditions, we have 
\begin_inset Formula 
\[
\left(1-\delta\right)V_{I}=\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{I}}{I_{j,I}^{\rho}}K_{j,I}^{-2}-r
\]

\end_inset

so we get 
\begin_inset Formula 
\[
\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{I}}{K_{j,I}}I_{j,I}^{-\rho-1}\rho-r+\frac{\beta}{1-\delta}\left(\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{I}}{I_{j,I}^{\rho}}K_{j,I}^{-2}-r\right)=0
\]

\end_inset

Now impose the condition 
\begin_inset Formula $K=\frac{1}{\delta}I.$
\end_inset

 And we get 
\begin_inset Formula 
\[
\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{I}}{\frac{1}{\delta}I_{j,I}}I_{j,I}^{-\rho-1}\rho-r+\frac{\beta}{1-\delta}\left(\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}\frac{c_{I}}{I_{j,I}^{\rho}}\left(\frac{1}{\delta}I_{j,I}\right)^{-2}-r\right)=0
\]

\end_inset


\begin_inset Formula 
\[
\left(\frac{1}{\sigma}\left(\frac{\sigma}{\sigma-1}\right)^{1-\sigma}\left(\frac{c_{A}}{I_{j,A}^{\rho}K_{,jA}}+\frac{c_{I}}{I_{j,I}^{\rho}K_{j,I}}\right)^{-\sigma}c_{I}I_{j,I}^{-\rho-2}\right)\left(\rho\delta+\frac{\beta}{1-\delta}\delta^{2}\right)-r\left(1+\frac{\beta}{1-\delta}\right)=0
\]

\end_inset

So we can get relative allocations, then absolute allocations.
