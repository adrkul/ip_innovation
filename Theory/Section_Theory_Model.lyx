\begin_layout Paragraph
Escape Competition
\end_layout

\begin_layout Standard
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\[
\max_{I_{f},\left\{ I_{f,j}\right\} _{j\in N}}\sum_{j}y_{f,j}\left(I_{f}^{\rho}I_{f,j}^{\rho}\right)^{\theta-1}-r\left(I_{f}+I_{f,j}\right)
\]

\end_inset

where 
\begin_inset Formula $y_{f,j}\equiv\bar{c}_{f,j}^{1-\theta}\left(\mu-1\right)\mu^{-\theta}x_{j}I_{j,I}^{-\rho}P_{j}^{-1}$
\end_inset

.
 Let's write 
\begin_inset Formula 
\[
\max_{I_{f},\left\{ I_{f,j}\right\} _{j\in N}}\sum_{j}\hat{y}_{f,j}\frac{\left(I_{f}^{\rho}I_{f,j}^{\rho}\right)^{\theta-1}}{P_{j}}-r\left(I_{f}+I_{f,j}\right)
\]

\end_inset


\begin_inset Formula 
\[
\max_{I_{f},\left\{ I_{f,j}\right\} _{j\in N}}\sum_{j}\hat{y}_{f,j}\frac{\left(I_{f}^{\rho}I_{f,j}^{\rho}\right)^{\theta-1}}{\left(I_{f}^{\rho}I_{f,j}^{\rho}\right)^{\theta}+\left(p_{\text{F}}\right)^{\theta}}-r\left(I_{f}+I_{f,j}\right)
\]

\end_inset

So we have with assumptions
\begin_inset Formula 
\[
\max_{I_{f},\left\{ I_{f,j}\right\} _{j\in N}}\hat{y}_{j}\frac{\left(I_{f}^{\rho}\right)^{\theta-1}}{\left(I_{f}^{\rho}\right)^{\theta}+\left(p_{\text{F}}\right)^{\theta}}-r\left(I_{f}\right)
\]

\end_inset

now we get to 
\begin_inset Formula 
\[
\hat{y}_{j}\frac{\rho\left(\theta-1\right)\left(I_{f}^{\rho}\right)^{\theta-2}\left(\left(I_{f}^{\rho}\right)^{\theta}+\left(p_{\text{F}}\right)^{\theta}\right)-\rho\left(\theta\right)\left(I_{f}^{\rho}\right)^{\theta-1}\left(I_{f}^{\rho}\right)^{\theta-1}}{\left(\left(I_{f}^{\rho}\right)^{\theta}+\left(p_{\text{F}}\right)^{\theta}\right)^{2}}-r=0
\]

\end_inset

So we get 
\begin_inset Formula 
\[
\frac{\rho\left(\theta-1\right)\left(I_{f}^{\rho}\right)^{\theta-2}}{\left(I_{f}^{\rho}\right)^{\theta}+\left(p_{\text{F}}\right)^{\theta}}-\frac{\rho\left(\theta\right)\left(I_{f}^{\rho}\right)^{\theta-1}\left(I_{f}^{\rho}\right)^{\theta-1}}{\left(\left(I_{f}^{\rho}\right)^{\theta}+\left(p_{\text{F}}\right)^{\theta}\right)^{2}}=\frac{r}{\hat{y}_{j}}
\]

\end_inset


\begin_inset Formula 
\[
\rho\left(\theta-1\right)\left(I_{f}^{\rho}\right)^{-2}\lambda_{f}-\frac{\rho\left(\theta\right)\left(I_{f}^{\rho}\right)^{2\theta-2}}{\left(\left(I_{f}^{\rho}\right)^{\theta}+\left(p_{\text{F}}\right)^{\theta}\right)^{2}}=\frac{r}{\hat{y}_{j}}
\]

\end_inset


\begin_inset Formula 
\[
\rho\left(\theta-1\right)\left(I_{f}^{\rho}\right)^{-2}\lambda_{f}-\rho\left(\theta\right)\left(I_{f}^{\rho}\right)^{-2}\lambda_{f}^{2}=\frac{r}{\hat{y}_{j}}
\]

\end_inset


\begin_inset Formula 
\[
I_{f}^{\rho}=\left(\left(\rho\left(\theta-1\right)\lambda_{f}-\rho\left(\theta\right)\lambda_{f}^{2}\right)\frac{\hat{y}_{j}}{r}\right)^{\frac{1}{2}}
\]

\end_inset

Suppose 
\begin_inset Formula $\lambda=1$
\end_inset

, then we have 
\begin_inset Formula 
\[
I_{f}^{\rho}=\left(\left(\rho\left(\theta-1\right)\lambda_{f}-\rho\left(\theta\right)\lambda_{f}^{2}\right)\frac{\hat{y}_{j}}{r}\right)^{\frac{1}{2}}
\]

\end_inset

and we have 
\begin_inset Formula 
\[
I_{f}^{\rho}=\left(\left(\rho\left(\theta-1\right)\lambda_{f}-\rho\left(\theta\right)\lambda_{f}^{2}\right)\frac{\hat{y}_{j}}{r}\right)^{\frac{1}{2}}
\]

\end_inset

if 
