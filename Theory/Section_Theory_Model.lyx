\begin_layout Standard
\begin_inset Formula 
\begin{equation}
c_{j}=\frac{\bar{c}_{j,A}}{I_{j,A}^{\eta}}+\frac{p_{j,I}}{I_{j,I}^{\eta}}\label{eq:Downstream-Costs}
