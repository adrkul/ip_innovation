\begin{alignedat}{1}d\log\bar{x}_{f,j}= & -\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\sum_{p}\lambda_{j,p}\sum_{f}\lambda_{j,p,f}d\log p_{f,j}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\sum_{p}\lambda_{j,p}\sum_{f}\lambda_{j,p,f}d\log p_{f,j}+\left(\theta-\frac{\rho}{1+\rho}\right)\sum_{f}\lambda_{j,p,f}d\log p_{f,j}\\
= & -\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\sum_{p}\lambda_{j,p}d\log P_{j,p}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\sum_{p}\lambda_{j,p}d\log P_{j,p}+\left(\theta-\frac{\rho}{1+\rho}\right)d\log P_{j,p}\\
\text{\{One Part\}}= & -\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}+\left(\theta-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}{}_{\text{}}\right)d\log P_{j,p}
\end{alignedat}
\]

\end_inset

Combining these results together yields
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log p_{f,j}= & \frac{1}{1+\varrho\left(1-\theta\right)}d\log c_{f,j}-\frac{\varrho}{1+\varrho\left(1-\theta\right)}\\
 & +\frac{-\rho}{1+2\left(1-\theta\right)}\sum\lambda_{f,j}\left(\frac{1-\theta}{1+\varrho\left(1-\theta\right)}d\log c_{f,j}+\frac{1}{1+\varrho\left(1-\theta\right)}d\log\bar{x}_{f,j}\right)\\
= & \frac{1}{1+\varrho\left(1-\theta\right)}d\log c_{f,j}-\frac{\varrho}{1+\varrho\left(1-\theta\right)}d\log\left[-\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}+\left(\theta-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right)d\log P_{j,p}\right]\\
 & +\frac{-\rho}{1+2\left(1-\theta\right)}\sum\lambda_{f,j}\left(\frac{1-\theta}{1+\varrho\left(1-\theta\right)}d\log c_{f,j}+\frac{1}{1+\varrho\left(1-\theta\right)}d\log\left[-\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}+\left(\theta-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right)d\log P_{j,p}\right]\right)\\
= & \frac{\varrho}{1+\varrho\left(1-\theta\right)}\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}+\frac{\rho}{1+2\left(1-\theta\right)}\frac{1}{1+\varrho\left(1-\theta\right)}\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}\\
 & +\frac{1}{1+\varrho\left(1-\theta\right)}d\log c_{f,j}-\frac{\varrho}{1+\varrho\left(1-\theta\right)}\left[\left(\theta-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right)d\log P_{j,p}\right]\\
 & +\frac{-\rho}{1+2\left(1-\theta\right)}\sum\lambda_{f,j}\left(\frac{1-\theta}{1+\varrho\left(1-\theta\right)}d\log c_{f,j}+\frac{1}{1+\varrho\left(1-\theta\right)}\left(\theta-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right)d\log P_{j,p}\right)\\
= & \left(\frac{\varrho}{1+\varrho\left(1-\theta\right)}+\frac{\rho}{1+2\left(1-\theta\right)}\frac{1}{1+\varrho\left(1-\theta\right)}\right)\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}\\
 & +d\log c_{f,j}-\frac{\rho\left(1-\theta\right)}{1+\varrho\left(1-\theta\right)}d\log c_{f,j}-\frac{\varrho}{1+\varrho\left(1-\theta\right)}\left[\tilde{\lambda}_{j,I}d\log P_{j,p}\right]\\
 & +\frac{-\rho}{1+2\left(1-\theta\right)}\frac{1}{1+\varrho\left(1-\theta\right)}\sum\lambda_{f,j}\left(\left(1-\theta\right)d\log c_{f,j}+\tilde{\lambda}_{j,I}d\log P_{j,p}\right)\\
= & \left(\frac{\varrho}{1+\varrho\left(1-\theta\right)}+\frac{\rho}{1+2\left(1-\theta\right)}\frac{1}{1+\varrho\left(1-\theta\right)}\right)\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}\\
 & +d\log c_{f,j}-\frac{\rho}{1+\varrho\left(1-\theta\right)}\left(\left(1-\theta\right)d\log c_{f,j}+\tilde{\lambda}_{j,I}d\log P_{j,p}\right)\\
 & +\frac{-\rho}{1+2\left(1-\theta\right)}\frac{1}{1+\varrho\left(1-\theta\right)}\sum\lambda_{f,j}\left(\left(1-\theta\right)d\log c_{f,j}+\tilde{\lambda}_{j,I}d\log P_{j,p}\right)\\
= & \underbrace{\left(\frac{\varrho}{1+\varrho\left(1-\theta\right)}+\frac{\rho}{1+2\left(1-\theta\right)}\frac{1}{1+\varrho\left(1-\theta\right)}\right)\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}}_{\delta_{1}=\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\times\left(\delta_{2}+\delta_{3}\right)}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}\\
 & +d\log c_{f,j}-\underbrace{\frac{\rho}{1+\varrho\left(1-\theta\right)}}_{\delta_{2}}\left(\left(1-\theta\right)d\log c_{f,j}+\tilde{\lambda}_{j,I}d\log P_{j,p}\right)\\
 & +\underbrace{\frac{-\rho}{1+2\left(1-\theta\right)}\frac{1}{1+\varrho\left(1-\theta\right)}}_{\delta_{3}}\sum\lambda_{f,j}\left(\left(1-\theta\right)d\log c_{f,j}+\tilde{\lambda}_{j,I}d\log P_{j,p}\right)\\
= & \delta_{1}\sum_{j}\lambda_{j}\lambda_{j,I}d\log P_{j}+d\log c_{f,j}-\delta_{2}\left(\left(1-\theta\right)d\log c_{f,j}+d\log P_{j,p}\right)-\delta_{3}\sum\lambda_{f,j}\left(\left(1-\theta\right)d\log c_{f,j}+\tilde{\lambda}_{j,I}d\log P_{j,p}\right)
\end{alignedat}
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Supplier Cost Shock - Corollary 
\begin_inset CommandInset ref
LatexCommand ref
reference "cor:GDP-Cost"
plural "false"
caps "false"
noprefix "false"

\end_inset


\end_layout

\begin_layout Standard
Start from Proposition 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop: Network Response"
plural "false"
caps "false"
noprefix "false"

\end_inset

 and simplify to the case of a single buyer:
\begin_inset Formula 
\[
d\log p_{f,j}=\delta_{1}\lambda_{j,I}d\log P_{j}+\left(1+\left(\theta-1\right)\left(\delta_{2}+\delta_{3}\right)\right)d\log c_{f,j}+\left[\left(\theta-1\right)-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right]d\log P_{j,p},
\]

\end_inset

and then aggregate across suppliers using supplier cost shares:
\begin_inset Formula 
\[
\sum_{f}\lambda_{j,f}d\log p_{f,j}=d\log P_{j}=\left(\delta_{1}\lambda_{j,I}-\left(\delta_{2}+\delta_{3}\right)\left(\left(\theta-1\right)-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right)\right)+\left(1+\left(\theta-1\right)\left(\delta_{2}+\delta_{3}\right)\right)\sum_{f}\lambda_{j,f}d\log c_{f,j}
\]

\end_inset

Now note that 
\begin_inset Formula $\delta_{1}=\left(\delta_{2}+\delta_{3}\right)\left(\sigma-1\right)/1+\rho\left(1-\sigma\right)$
\end_inset

 so that we can write 
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log P_{j}= & \left(\delta_{1}\lambda_{j,I}-\left(\delta_{2}+\delta_{3}\right)\left(-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right)-\left(\delta_{2}+\delta_{3}\right)\left(\theta-1\right)\right)d\log P_{j,p}+\left(1+\left(\theta-1\right)\left(\delta_{2}+\delta_{3}\right)\right)\sum_{f}\lambda_{j,f}d\log c_{f,j}\\
= & \left(\delta_{2}+\delta_{3}\right)\left(\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\lambda_{j,I}-\left(-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}\right)-\left(\theta-1\right)\right)d\log P_{j,p}+\left(1+\left(\theta-1\right)\left(\delta_{2}+\delta_{3}\right)\right)\sum_{f}\lambda_{j,f}d\log c_{f,j}\\
= & \left(\delta_{2}+\delta_{3}\right)\left(\left(\frac{1-\sigma}{1+\rho\left(1-\sigma\right)}+\frac{\sigma}{1+\eta\left(1-\sigma\right)}\frac{1}{1+\rho}\right)\lambda_{j,I}+\frac{\eta}{1+\eta}-\left(\theta-1\right)\right)d\log P_{j,p}+\left(1+\left(\theta-1\right)\left(\delta_{2}+\delta_{3}\right)\right)\sum_{f}\lambda_{j,f}d\log c_{f,j}\\
= & \left(\delta_{2}+\delta_{3}\right)\left(\left(\frac{1-\sigma+\rho-\sigma\rho+\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\right)\lambda_{j,I}+\frac{\eta}{1+\eta}-\left(\theta-1\right)\right)d\log P_{j,p}+\left(1+\left(\theta-1\right)\left(\delta_{2}+\delta_{3}\right)\right)\sum_{f}\lambda_{j,f}d\log c_{f,j}\\
= & \left(\delta_{2}+\delta_{3}\right)\left(\frac{1}{1+\eta}\lambda_{j,I}+\frac{\eta}{1+\eta}-\left(\theta-1\right)\right)d\log P_{j,p}+\left(1+\left(\theta-1\right)\left(\delta_{2}+\delta_{3}\right)\right)\sum_{f}\lambda_{j,I}d\log c_{f,j}
\end{alignedat}
\]

\end_inset

Where we can collect terms to either side and write 
\begin_inset Formula 
\[
d\log P_{j,p}=\sum_{f}\lambda_{j,f}d\log p_{f,j}=\frac{1+\left(\delta_{2}+\delta_{3}\right)\left(\theta-1\right)}{1+\left(\delta_{2}+\delta_{3}\right)\left(\left(\theta-1\right)-\frac{1}{1+\eta}\lambda_{j,I}-\frac{\eta}{1+\eta}\right)}\sum_{f}\lambda_{j,f}d\log c_{f,j}
\]

\end_inset

which we can combine with Proposition 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:GDP-Response"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 Which can be simplified to 
\begin_inset Formula 
\[
\frac{1+\left(\delta_{2}+\delta_{3}\right)\left(\theta-1\right)}{1+\left(\delta_{2}+\delta_{3}\right)\left(\left(\theta-1\right)-\frac{1}{1+\eta}\lambda_{j,I}-\frac{\eta}{1+\eta}\right)}\sum_{f}\lambda_{j,f}d\log c_{f,j}=\frac{1}{1-2\rho\left(\frac{1}{1+\eta}\lambda_{j,I}+\frac{\eta}{1+\eta}\right)}\sum_{f}\lambda_{j,f}d\log c_{f,j}
\]

\end_inset


\end_layout

\begin_layout Subsection
Supplier R&D Shock - Proposition 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop: Network Response - R&D"
plural "false"
caps "false"
noprefix "false"

\end_inset


\end_layout

\begin_layout Standard
We start from decomposing the change in R&D efficiency into the exogenous
 and endogenous component:
\begin_inset Formula 
\[
d\log\bar{\zeta}_{f}=\sum_{c}\lambda_{f,c}\left(d\log\zeta_{f,c}+\omega d\log K_{c}\right)
\]

\end_inset

where using 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:R&D-Country-Allocation"
plural "false"
caps "false"
noprefix "false"

\end_inset

, we have 
\begin_inset Formula 
\[
d\log I_{f,c}+d\log\zeta_{f,c}=\frac{1}{1-\varsigma}\left(d\log\zeta_{f,c}+\omega d\log K_{c}\right)-\frac{1}{1-\varsigma}\sum_{c}\lambda_{f,c}\left(d\log\zeta_{f,c}+\omega d\log K_{c}\right)+d\log I_{f}
\]

\end_inset

We additionally have 
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log K_{c}= & \sum_{f}\lambda_{c,f}\left(d\log I_{f,c}+d\log\zeta_{f,c}\right)+\sum_{f}\lambda_{c,f,j}\left(d\log I_{f,j,c}+d\log\zeta_{f,j,c}\right)\\
 & +\sum_{j}\lambda_{c,j,A}\left(d\log I_{j,A}+d\log\zeta_{j,A,c}\right)+\sum_{j}\lambda_{c,j,I}\left(d\log I_{j,I}+d\log\zeta_{j,I,c}\right)
\end{alignedat}
.
\]

\end_inset

Now specialize to the case where only 
\begin_inset Formula $d\log\bar{\zeta}_{f}\neq0$
\end_inset

, then we have 
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log K_{c}= & \sum_{f}\lambda_{c,f}\left(\frac{1}{1-\varsigma}\left(d\log\zeta_{f,c}+\omega d\log K_{c}\right)-\frac{1}{1-\varsigma}\sum_{c'}\lambda_{f,c'}\left(d\log\zeta_{f,c'}+\omega d\log K_{c'}\right)\right)\\
 & +\sum_{f}\lambda_{c,f}d\log I_{f}+\sum_{f}\lambda_{c,f,j}d\log I_{f,j}+\sum_{j}\lambda_{c,j,A}d\log I_{j,A}+\sum_{j}\lambda_{c,j,I}d\log I_{j,I}
\end{alignedat}
\]

\end_inset

Now note the following
\begin_inset Formula 
\begin{equation}
\begin{alignedat}{1}\begin{alignedat}{1}d\log p_{f,j}=\end{alignedat}
 & -\rho d\log I_{f,j}-\rho d\log I_{f}\\
d\log p_{j}= & -\eta\lambda_{j,A}d\log I_{j,A}-\eta\lambda_{j,I}d\log I_{j,I}
\end{alignedat}
\label{eq:Price-R&D-Change}
\end{equation}

\end_inset

which lets us write
\begin_inset Formula 
\[
\begin{alignedat}{1}\sum_{f}\lambda_{c,f}d\log I_{f}+\sum_{f,j}\lambda_{c,f,j}d\log I_{f,j}= & \sum_{f}\frac{I_{f,c}+\sum_{j}I_{f,j,c}}{I_{f,c}+\sum_{j}I_{f,j,c}+...}\left(\frac{I_{f,c}}{I_{f,c}+\sum_{j}I_{f,j,c}}d\log I_{f}+\sum_{j}\frac{I_{f,j,c}}{I_{f,c}+\sum_{j}I_{f,j,c}}d\log I_{f,j}\right)\\
= & \sum_{f}\frac{I_{f,c}+\sum_{j}I_{f,j,c}}{I_{f,c}+\sum_{j}I_{f,j,c}+...}\left(\frac{I_{f}}{I_{f}+I_{f,j}}d\log I_{f}+\sum_{j}\frac{I_{f,j}}{I_{f}+I_{f,j}}d\log I_{f,j}\right)\\
= & -\sum_{f}\frac{I_{f,c}+\sum_{j}I_{f,j,c}}{I_{f,c}+\sum_{j}I_{f,j,c}+...}\left(\frac{1}{2\rho}\sum d\log p_{f,j}\right)\\
= & -\sum_{f}\lambda_{c,f}\left(\frac{1}{2\rho}\sum d\log p_{f,j}\right)
\end{alignedat}
\]

\end_inset

where we us 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:Price-R&D-Change"
plural "false"
caps "false"
noprefix "false"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:R&D-Country-Allocation"
plural "false"
caps "false"
noprefix "false"

\end_inset

, and Proposition X, under the assumption that 
\begin_inset Formula $\zeta_{f,c}=\zeta_{f,j,c}\forall c$
\end_inset

.
 We can do the same for 
\begin_inset Formula $j$
\end_inset

, and note that 
\begin_inset Formula 
\[
\begin{alignedat}{1}\sum_{j}\lambda_{c,j,A}d\log I_{j,A}+\sum_{j}\lambda_{c,j,I}d\log I_{j,I}= & \sum_{j}\frac{I_{j,A,c}+I_{j,I,c}}{I_{j,A,c}+I_{j,I,c}+...}\left(\frac{I_{j,A,c}}{I_{j,A,c}+I_{j,I,c}}d\log I_{j,A}+\frac{I_{j,I,c}}{I_{j,A,c}+I_{j,I,c}}d\log I_{j,I}\right)\\
= & \sum_{j}\frac{I_{j,A,c}+I_{j,I,c}}{I_{j,A,c}+I_{j,I,c}+...}\left(\frac{I_{j,A}}{I_{j,A}+I_{j,I}}d\log I_{j,A}+\frac{I_{j,A}}{I_{j,A}+I_{j,I}}d\log I_{j,I}\right)\\
= & -\sum_{j}\frac{I_{j,A,c}+I_{j,I,c}}{I_{j,A,c}+I_{j,I,c}+...}\left(\frac{1}{\eta}d\log p_{j}\right)\\
= & -\sum_{j}\lambda_{c,j}\left(\frac{1}{\eta}d\log p_{j}\right)
\end{alignedat}
.
\]

\end_inset

All in all, we have 
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log K_{c}= & \sum_{f}\lambda_{c,f}\left(\frac{1}{1-\varsigma}\left(d\log\zeta_{f,c}+\omega d\log K_{c}\right)-\frac{1}{1-\varsigma}\sum_{c'}\lambda_{f,c'}\left(d\log\zeta_{f,c'}+\omega d\log K_{c'}\right)\right)\\
 & -\sum_{f}\lambda_{c,f}\left(\frac{1}{2\rho}\sum_{j}d\log p_{f,j}\right)-\sum_{j}\lambda_{c,j}\left(\frac{1}{\eta}d\log p_{j}\right)
\end{alignedat}
\]

\end_inset

Hence we can combine with X to write 
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log\bar{\zeta}_{f}= & \sum_{c\in C_{f}}\lambda_{f,c}\Biggl(d\log\zeta_{f,c}+\frac{\omega}{1-\varsigma}\sum_{f}\lambda_{c,f}\left(\frac{1}{1-\varsigma}\left(d\log\zeta_{f,c}+\omega d\log K_{c}\right)-\frac{1}{1-\varsigma}\sum_{c'}\lambda_{f,c'}\left(d\log\zeta_{f,c'}+\omega d\log K_{c'}\right)\right)\\
 & \quad-\frac{\omega}{2\rho}\sum_{f,j}\lambda_{c,f,j}d\log p_{f,j}-\frac{\omega}{\eta}\sum_{j}\lambda_{c,j}d\log p_{j}
\end{alignedat}
\]

\end_inset


\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
.
\begin_inset Formula 
\[
d\log K_{c}-\sum_{c'}\lambda_{f,c'}d\log K_{c'}
\]

\end_inset

we can write this as 
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log K_{c}= & \sum_{f}\lambda_{c,f}\left(\frac{1}{1-\varsigma}\left(d\log\zeta_{f,c}+\omega d\log K_{c}\right)-\frac{1}{1-\varsigma}\sum_{c'}\lambda_{f,c'}\left(d\log\zeta_{f,c'}+\omega d\log K_{c'}\right)\right)\\
 & -\sum_{f}\lambda_{c,f}\left(\frac{1}{2\rho}\sum_{j}d\log p_{f,j}\right)-\sum_{j}\lambda_{c,j}\left(\frac{1}{\eta}d\log p_{j}\right)
\end{alignedat}
\]

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Subsection
Supplier R&D Shock - Corollary
\end_layout

\begin_layout Standard
We have 
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
.
\begin_inset Formula 
\[
p_{f,j}=\mu_{f,j}c_{f,j}\left(\varrho\bar{\zeta}_{f,j}\bar{x}_{f,j}\mu_{f,j}^{-\theta}\bar{c}_{f,j}^{1-\theta}\right)^{\frac{-\varrho}{1+\varrho\left(1-\theta\right)}}\left(\sum_{j}\frac{\rho\bar{\zeta}_{f}}{\varrho\bar{\zeta}_{f,j}}\left(\bar{\zeta}_{f,j}\bar{x}_{f,j}\mu_{f,j}^{-\theta}\bar{c}_{f,j}^{1-\theta}\right)^{\frac{1}{1+\varrho\left(1-\theta\right)}}\right)^{\frac{-\rho}{1+\left(\rho+\varrho\right)\left(1-\theta\right)}}
\]

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\[
d\log p_{f,j}=-\frac{\varrho}{1+\varrho\left(1-\theta\right)}d\log\bar{x}_{f,j}+\frac{-\rho}{1+2\rho\left(1-\theta\right)}\sum\lambda_{f,j}\left(d\log\bar{\zeta}_{f}+\frac{1}{1+\varrho\left(1-\theta\right)}d\log\bar{x}_{f,j}\right)
\]

\end_inset

which in the case of a single buyer becomes 
\begin_inset Formula 
\[
d\log p_{f,j}=\frac{-2\rho}{1+2\rho\left(1-\theta\right)}d\log\bar{x}_{f,j}+\frac{-\rho}{1+2\rho\left(1-\theta\right)}d\log\bar{\zeta}_{f}.
\]

\end_inset

Now we have
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
.
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log\bar{x}_{f,j}= & -\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\lambda_{j,I}d\log P_{j}+\left(\theta-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}{}_{\text{}}\right)d\log P_{j,p}\end{alignedat}
\]

\end_inset


\begin_inset Formula 
\[
\begin{alignedat}{1}d\log\bar{x}_{f,j}= & -\left(\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}+\frac{\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\right)\lambda_{j,I}d\log P_{j}+\left(\theta-\frac{\rho}{1+\rho}\right)d\log P_{j,p}\end{alignedat}
\]

\end_inset


\begin_inset Formula 
\[
\begin{alignedat}{1}d\log\bar{x}_{f,j}= & -\left(\frac{\left(1-\sigma\right)\left(1+\rho\right)}{1+\rho\left(1-\sigma\right)}+\frac{\sigma}{1+\rho\left(1-\sigma\right)}\right)\frac{1}{1+\rho}\lambda_{j,I}d\log P_{j}+\left(\theta-\frac{\rho}{1+\rho}\right)d\log P_{j,p}\end{alignedat}
\]

\end_inset


\begin_inset Formula 
\[
\begin{alignedat}{1}d\log\bar{x}_{f,j}= & \left(\theta-\frac{\rho}{1+\rho}-\frac{1}{1+\rho}\lambda_{j,I}\right)d\log P_{j,p}\end{alignedat}
\]

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\[
\begin{alignedat}{1}d\log\bar{x}_{f,j}= & -\frac{\left(1-\sigma\right)}{1+\rho\left(1-\sigma\right)}\lambda_{j,I}d\log P_{j}+\left(\theta-\frac{\rho}{1+\rho}+\frac{-\sigma}{1+\rho\left(1-\sigma\right)}\frac{1}{1+\rho}\lambda_{j,I}{}_{\text{}}\right)d\log P_{j,p}\end{alignedat}
\]

\end_inset

which in the case of a ingle buyer becomes 
\begin_inset Formula 
\[
d\log\bar{x}_{f,j}=\left(\theta-\frac{\eta}{1+\eta}-\frac{1}{1+\eta}\lambda_{j,I}\right)d\log P_{j,p}.
\]

\end_inset

And, in the case of a single location Proposition X, becomes 
\begin_inset Formula 
\[
\begin{alignedat}{1}d\log\bar{\zeta}_{f}=\sum_{c}\lambda_{f,c} & d\log\zeta_{f,c}-\frac{\omega}{2\rho}\sum_{f,j}\lambda_{c,f,j}d\log p_{f,j}-\frac{\omega}{\eta}\sum_{j}\lambda_{c,j}d\log p_{j}\end{alignedat}
,
\]

\end_inset

So we can write, by combining X and X, and noting that 
\begin_inset Formula $\sum_{f}\lambda_{j,f}d\log p_{f,j}=d\log P_{j},$
\end_inset

we have
