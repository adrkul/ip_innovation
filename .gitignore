# ==============================================================================
# .gitignore for IP Innovation Research Project
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# LyX backup and autosave files
*.lyx~
*.lyx#
#*.lyx#

# Compiled PDFs (tracked selectively — keep final paper and slide PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# ==============================================================================
# Large Data Files (NEVER commit — proprietary or too large)
# ==============================================================================

# All raw and intermediate data in Empirics/Data/
Empirics/Data/**
!Empirics/Data/.gitkeep

# Large simulation inputs
Simulation/Data/*.csv
Simulation/Data/*.jld2

# All model output in Simulation/Output/
Simulation/Output/**
!Simulation/Output/.gitkeep

# ==============================================================================
# Julia Artifacts
# ==============================================================================

# Julia compiled artifacts (regenerated automatically)
*.ji

# Julia package manifests (pin with Project.toml instead)
# Uncomment below if you want to track exact dependency versions:
# !Manifest.toml

# Local Julia depot artifacts
.julia/

# ==============================================================================
# R Data Artifacts (selective — see data-management.md rule)
# ==============================================================================

# Diagnostic/scratch figures (not for paper)
Empirics/Figures/Scratch/

# Uncomment to ignore all RDS files (except small tracked ones):
# *.rds
