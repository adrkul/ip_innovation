\begin_layout Subsection
Downstream Firms
\end_layout

\begin_layout Standard
I now turn to the empirical model for downstream firms (OEMs).
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
.
\begin_inset Formula 
\[
\sum_{k}D_{k}\left(\left(\frac{c_{j,A,k}}{I_{j,A}^{\rho}}\right)^{\varrho}+\sum\left(\frac{c_{j,p,k}}{I_{j,p}^{\rho}}\right)^{\varrho}\right)^{\frac{1}{\varrho}\left(1-\sigma\right)}
\]

\end_inset


\begin_inset Formula 
\[
\sum_{k}D_{k}\left(\frac{D_{k}}{\sum_{_{k}}D_{k}}\right)^{\left(\sigma-1\right)}\left(\left(\frac{\frac{D_{k}}{\sum_{_{k}}D_{k}}c_{j,A,k}}{I_{j,A}^{\rho}}\right)^{\varrho}+\sum\left(\frac{\frac{D_{k}}{\sum_{_{k}}D_{k}}c_{j,p,k}}{I_{j,p}^{\rho}}\right)^{\varrho}\right)^{\frac{1}{\varrho}\left(1-\sigma\right)}
\]

\end_inset


\begin_inset Formula 
\[
\sum_{k}\left(\left(\frac{\frac{D_{k}}{\sum_{_{k}}D_{k}}c_{j,A,k}}{I_{j,A}^{\rho}}\right)^{\varrho}+\sum\left(\frac{\frac{D_{k}}{\sum_{_{k}}D_{k}}c_{j,p,k}}{I_{j,p}^{\rho}}\right)^{\varrho}\right)^{\frac{1}{\varrho}\left(1-\sigma\right)}
\]

\end_inset


\begin_inset Formula 
\[
\sum_{k}D_{k}^{\sigma}\left(\frac{1}{\sum_{_{k}}D_{k}}\right)^{\left(\sigma-1\right)}\left(\left(\frac{\bar{c}_{j,A,}}{I_{j,A}^{\rho}}\right)^{\varrho}+\sum\left(\frac{\bar{c}_{j,p}}{I_{j,p}^{\rho}}\right)^{\varrho}\right)^{\frac{1}{\varrho}\left(1-\sigma\right)}
\]

\end_inset


\begin_inset Formula 
\[
\sum_{k}D_{k}^{\sigma}\left(\frac{1}{\sum_{_{k}}D_{k}}\right)^{\left(\sigma-1\right)}\left(\left(\frac{\bar{c}_{j,A,}}{I_{j,A}^{\rho}}\right)^{\varrho}+\sum\left(\frac{\bar{c}_{j,p}}{I_{j,p}^{\rho}}\right)^{\varrho}\right)^{\frac{1}{\varrho}\left(1-\sigma\right)}
\]

\end_inset


\end_layout

\end_inset

 I start with the demand system faced by OEMs', which is over the final
 assembled goods.
 Following the microfoundation from Section X, demand for OEM 
\begin_inset Formula $j$
\end_inset

 in a market 
\begin_inset Formula $k$
\end_inset

 (defined at the country-level) is 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
q_{j,k}=D_{k}\frac{\xi_{j,k}p_{j,k}^{-\sigma}}{P_{k}^{1-\sigma}},\label{eq: Market Demand - Downstream}
\end{equation}

\end_inset

where 
\begin_inset Formula $D_{k}$
\end_inset

 is the total demand, 
\begin_inset Formula $\xi_{j,c}$
\end_inset

 is an idiosyncratic demand shifter, and 
\begin_inset Formula $P_{k}^{1-\sigma}=\sum_{j\in F\left(k\right)}p_{j,k}^{1-\sigma}\xi_{j,k}$
\end_inset

 is the final-goods price index over the set of active OEMs in a market
 
\begin_inset Formula $F(k)$
\end_inset

.
 
\end_layout

\begin_layout Standard
OEMs produce final goods using an assembly input and a bundle of parts.
 To this end, let 
\begin_inset Formula $A$
\end_inset

 index assembly and 
\begin_inset Formula $p\in\mathcal{P}$
\end_inset

 index parts.
 An OEM's production function is CES over these components with elasticity
 of substitution 
\begin_inset Formula $\nu$
\end_inset

, such that the unit cost of producing vehicle 
\begin_inset Formula $j$
\end_inset

 for market 
\begin_inset Formula $k$
\end_inset

 is 
\begin_inset Formula 
\begin{equation}
mc_{j,k}=\left(\left(\frac{c_{j,A,k}\chi_{j,A}}{I_{j,A}^{\eta}}\right)^{1-\upsilon}+\sum_{p\in\mathcal{P}}\left(\frac{p_{j,p,k}\chi_{j,p}}{I_{j,p}^{\eta}}\right)^{1-\upsilon}\right)^{\frac{1}{1-\upsilon}}.\label{eq: OEM costs}
\end{equation}

\end_inset

The terms 
\begin_inset Formula $c_{j,A,k}$
\end_inset

 and 
\begin_inset Formula $\chi_{j,A}$
\end_inset

 represent the baseline assembly costs as well as idiosyncratic cost shocks,
 while 
\begin_inset Formula $p_{j,p,k}$
\end_inset

 and 
\begin_inset Formula $\chi_{j,p}$
\end_inset

 represent the same for parts prices.
 Otherwise, 
\begin_inset Formula $I_{j,A}$
\end_inset

 and 
\begin_inset Formula $I_{j,p}$
\end_inset

 represent R&D in assembly and parts.
 Unlike suppliers, which take prices as given from a contracting process,
 buyers set their own prices in addition to determining levels of R&D.
 Both are chosen optimally to maximize profits:
\begin_inset Formula 
\[
\max_{p_{j,k},I_{f,A,c},I_{f,p,c}}\sum_{k}D_{k}\frac{\xi_{j,k}p_{j,k}^{-\sigma}}{P_{k}^{1-\sigma}}\left(p_{j,k}-mc_{j,k}\right)-\sum_{c}r_{c}^{\zeta}\left(I_{j,A,c}+\sum_{p}I_{j,p,c}\right),
\]

\end_inset

subject to the marginal cost expression in 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq: OEM costs"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 OEMs take part prices as given at the R&D stage (see Figure X), but they
