\begin_inset Formula 
\[
I_{f}=\left(\sum_{j}\frac{\rho\bar{\zeta}_{f}}{\varrho\bar{\zeta}_{f,j}}\left(\varrho\bar{\zeta}_{f,j}\bar{q}_{f,j}\bar{c}_{f,j}\right)^{\frac{1}{1+\varrho}}\right)^{\frac{1+\varrho}{1+\rho+\varrho}}\text{ and }I_{f,j}=\left(\varrho\bar{\zeta}_{f,j}\bar{q}_{f,j}\bar{c}_{f,j}\right)^{\frac{1}{1+\varrho}}I_{f}^{\frac{-\rho}{1+\varrho}}
\]

