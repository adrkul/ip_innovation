\shape default

\begin_inset Formula 
\[
\frac{I_{j,x,c}}{\sum_{c'}I_{j,x,c'}}=\frac{\left(\zeta_{j,x,c}/r_{c}\right)^{\frac{\varsigma}{1-\varsigma}}}{\sum_{c'}\left(\zeta_{j,x,c'}/r_{c'}\right)^{\frac{\varsigma}{1-\varsigma}}}.
\]

\end_inset


\end_layout

