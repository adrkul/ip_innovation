\sum_{p}\left(\frac{I_{j,p}}{\bar{\zeta}_{j,p}}\right)=\left(\sum_{p}\left(\frac{\bar{c}_{j,A}}{\bar{\zeta}_{j,p}^{\rho}}\right)^{\frac{\varrho}{1+\rho\varrho}}\right)^{\frac{1}{\varrho}\frac{1+\varrho\rho}{1+\rho}}\bar{q}_{j}^{\frac{1}{1+\rho}}
\]

\end_inset

and we have 
\begin_inset Formula 
\[
\frac{I_{j,p}}{I_{j,p'}}=\left(\frac{\bar{\zeta}_{j,p}\bar{c}_{j,p}^{\varrho}}{\bar{\zeta}_{j,p}\bar{c}_{j,p}^{\varrho}}\right)^{\frac{1}{1+\rho\varrho}}
\]

\end_inset

or 
\begin_inset Formula 
\[
\frac{I_{j,p}/\bar{\zeta}_{j,p}}{I_{j,p'}/\bar{\zeta}_{j,p}}=\left(\frac{\bar{c}_{j,p}/\bar{\zeta}_{j,p}^{\rho}}{\bar{c}_{j,p}/\bar{\zeta}_{j,p}^{\rho}}\right)^{\frac{\varrho}{1+\rho\varrho}}
\]

\end_inset

So we have 
\begin_inset Formula 
\[
I_{j,p}=\bar{\zeta}_{j,p}\frac{I_{j,p}/\bar{\zeta}_{j,p}}{\sum_{j,p}I_{j,p'}/\bar{\zeta}_{j,p}}\sum_{j,p}I_{j,p'}/\bar{\zeta}_{j,p}=\bar{\zeta}_{j,p}\frac{\left(\bar{c}_{j,p}/\bar{\zeta}_{j,p}^{\rho}\right)^{\frac{\varrho}{1+\rho\varrho}}}{\sum_{j,p}\left(\bar{c}_{j,p}/\bar{\zeta}_{j,p}^{\rho}\right)^{\frac{\varrho}{1+\rho\varrho}}}\left(\left(\sum_{p}\left(\frac{\bar{c}_{j,A}}{\bar{\zeta}_{j,p}^{\rho}}\right)^{\frac{\varrho}{1+\rho\varrho}}\right)^{\frac{1}{\varrho}\frac{1+\varrho\rho}{1+\rho}}\bar{q}_{j}^{\frac{1}{1+\rho}}\right)
\]

\end_inset

and we have 
\begin_inset Formula 
\[
\frac{\left[\zeta_{j,c}d_{j,c}^{-\tau_{p}}\lambda_{j,c}^{-1}\right]^{\varsigma}I_{j,c}^{\zeta-1}}{\left[\zeta_{j,c'}d_{j,c'}^{-\tau_{p}}\lambda_{j,c'}^{-1}\right]^{\varsigma}I_{j,c'}^{\zeta-1}}=1\implies\left[\frac{\zeta_{j,c}d_{j,c}^{-\tau_{p}}\lambda_{j,c}^{-1}}{\zeta_{j,c'}d_{j,c'}^{-\tau_{p}}\lambda_{j,c'}^{-1}}\right]^{\frac{\varsigma}{1-\varsigma}}=\frac{I_{f,c}}{I_{f,c'}}.
\]

\end_inset


\begin_inset Formula 
\[
\left[\left(\frac{c_{j,A}}{I_{j,A}^{\rho}}\right)^{\varrho}+\left(\sum_{p}\frac{c_{j,p}}{I_{j,p}^{\rho}}\right)^{\varrho}\right]^{\frac{1}{\varrho}}=\left(\rho\bar{q}_{j}\right)^{-\frac{\rho}{1+\rho}}\left(\left(\frac{\bar{c}_{j,A}}{\bar{\zeta}_{j,p}^{\rho}}\right)^{\frac{\varrho}{1+\rho\varrho}}+...\right)^{\frac{1}{\varrho}\frac{1+\rho\varrho}{1+\rho}}
\]

\end_inset

Suppose one product now
\begin_inset Formula 
\[
I_{j,p}=\bar{\zeta}_{j,p}\sum_{j,p}I_{j,p'}/\bar{\zeta}_{j,p}=\bar{\zeta}_{j,p}\left(\left(\sum_{p}\left(\frac{\bar{c}_{j,A}}{\bar{\zeta}_{j,p}^{\rho}}\right)^{\frac{\varrho}{1+\rho\varrho}}\right)^{\frac{1}{\varrho}\frac{1+\varrho\rho}{1+\rho}}\bar{q}_{j}^{\frac{1}{1+\rho}}\right)
\]

\end_inset


\begin_inset Formula 
\[
I_{j,p}=\bar{\zeta}_{j,p}\sum_{j,p}I_{j,p'}/\bar{\zeta}_{j,p}=\left(\bar{\zeta}_{j,p}\bar{c}_{j,A}\bar{q}_{j}\right)^{\frac{1}{1+\rho}}
\]

\end_inset


\begin_inset Formula 
\[
I_{f}=\left(\rho\varrho^{\frac{-\varrho}{1+\varrho}}\bar{\zeta}_{f}\sum_{j}\left(\bar{q}_{f,j}\bar{c}_{f,j}\bar{\zeta}_{f,j}^{-\varrho}\right)^{\frac{1}{1+\varrho}}\right)^{\frac{1+\varrho}{1+\rho+\varrho}}
\]

\end_inset


